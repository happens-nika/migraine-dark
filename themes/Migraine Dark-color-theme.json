{
	"name": "Dark Alabaster theme",
	"type": "dark",
	"tokenColors": [
		{
			"name": "Comment",
			"scope": [
				"comment",
				"punctuation.definition.comment"
			],
			"settings": {
				"foreground": "#b58848"
			}
		},
		{
			"name": "Punctuation",
			"scope": "punctuation",
			"settings": {
				"foreground": "#8fadaf"
			}
		},
		{
			"name": "Conditionals",
			"scope": [
				"keyword",
				"storage.type.function.arrow"
			],
			"settings": {
				"foreground": "#999"
			}
		},
		{
			"name": "Strings",
			"scope": [
				"string",
				"string.regexp",
				"string.other.symbol",
				"punctuation.definition.string",
				"punctuation.definition.template-expression"
			],
			"settings": {
				"foreground": "#dad8d8"
			}
		},
		{
			"name": "Numbers, Characters",
			"scope": [
				"constant.numeric",
				"constant.character",
				"constant.keyword",
				"constant",
			],
			"settings": {
				"foreground": "#999"
			}
		},
		{
			"name": "meta.function-call",
			"scope": "meta.function-call",
			"settings": {
				"foreground": "#999"
			}
		},
		{
			"name": "tags",
			"scope": "entity.name.tag",
			"settings": {
				"foreground": "#999",
			}
		},
		{
			"name": "Punctuations",
			"scope": "punctuation",
			"settings": {
				"foreground": "#999"
			}
		},
		{
			"name": "Invalid",
			"scope": "invalid",
			"settings": {
				"foreground": "#c33"
			}
		},
		{
			"name": "?",
			"scope": [
				"variable.other.constant",
				//"meta.definition.variable"
			],
			"settings": {
				"foreground": "#EEE",
			}
		},
		{
			"name": "??",
			"scope": [
				"meta.definition.variable"
			],
			"settings": {
				"foreground": "#EEE",
			}
		},
		{
			"name": "Meta",
			"scope": [
				"meta.block.js"
			],
			"settings": {
				"foreground": "#999"
			}
		}
	],
	"colors": {
		"editor.background": "#0E1415",
		"editor.foreground": "#a7a7a7",
		"titleBar.activeBackground": "#1f2425",
		"titleBar.inactiveBackground": "#1f2425",
		"editorGroupHeader.tabsBackground": "#1f2425",
		"tab.inactiveBackground": "#212627",
		"panel.background": "#1f2425",
		"activityBar.background": "#1f2425",
		"sideBarTitle.foreground": "#828282",
		"sideBar.background": "#1f2425",
		"list.dropBackground": "#595959",
		"focusBorder": "#0E1415",
		"list.activeSelectionBackground": "#595959",
		"list.inactiveSelectionBackground": "#595959",
		"editorCursor.foreground": "#b58848",
		"editorError.foreground": "#595959",
